# Copiá este archivo a .env y poné valores REALES. NUNCA subas .env a git.
#   cp .env.example .env   &&   editá .env

# --- PostgreSQL ---
POSTGRES_USER=lockatus
POSTGRES_PASSWORD=cambiame-por-una-contraseña-larga-y-fuerte
POSTGRES_DB=lockatus

# --- Admin que comisiona el sistema (primer superadmin) ---
LOCKATUS_ADMIN_EMAIL=admin@tu-organizacion.org
# Dejá esto VACÍO: en el primer arranque se genera una contraseña fuerte y se imprime
# UNA vez en los logs (docker compose logs lockatus). Cambiala desde el panel después.
LOCKATUS_ADMIN_PASS=

# --- Clave maestra del servidor (OBLIGATORIA) ---
# Cifra al guardar los secretos TOTP y firma la cookie de sesión del hub. Generá una con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si la perdés, los 2FA enrolados dejan de validar (hay que re-enrolar) — guardala bien.
LOCKATUS_SECRET=

# --- Identidad pública del emisor (issuer OIDC) ---
# La URL pública por la que las apps llegan a Lockatus. Va en los tokens (iss) y en el JWKS.
LOCKATUS_ISSUER=http://localhost:8081

# --- Seguridad / despliegue ---
# Poné 1 cuando Lockatus corra detrás de TLS (reverse proxy / HTTPS): la cookie solo por HTTPS.
LOCKATUS_SECURE_COOKIE=0
# Puerto del host (el server escucha en 8080 dentro del contenedor):
LOCKATUS_PORT=8081
